APP_NAME=DevOps IPAM
ENVIRONMENT=dev
DEBUG=true
API_V1_PREFIX=/api/v1
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
DATABASE_URL=postgresql+asyncpg://ipam:ipam@db:5432/ipam
JWT_SECRET_KEY=replace_with_a_very_long_random_secret_key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_MINUTES=10080
COOKIE_SECURE=false
RATE_LIMIT_PER_MINUTE=120
REDIS_URL=
CSV_MAX_SIZE_BYTES=2097152
ADMIN_EMAIL=admin@ipam.local
ADMIN_PASSWORD=ChangeMe_Strong_Password123!
